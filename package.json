{
  "name": "@requence/cache",
  "version": "1.0.0",
  "description": "Tag-based function caching with pluggable backends — memory, Redis, or both",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./redis": {
      "bun": "./src/backends/RedisBackend.ts",
      "types": "./dist/backends/RedisBackend.d.ts",
      "import": "./dist/backends/RedisBackend.js",
      "default": "./dist/backends/RedisBackend.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "test": "bun test",
    "check-types": "tsc --noEmit",
    "cs": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "node-object-hash": "^3.1.1"
  },
  "peerDependencies": {
    "ioredis": "^5.9.3",
    "superjson": "^2.2.5"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "superjson": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "latest",
    "ioredis": "^5.9.3",
    "superjson": "^2.2.5",
    "typescript": "^5.9.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/requence/cache.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
